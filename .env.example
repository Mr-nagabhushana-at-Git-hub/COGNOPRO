# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/cogno

# AI providers are tried in this order: Ollama, Anthropic, OpenAI, Hugging Face.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
LOCAL_AI_TIMEOUT_MS=1500
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=

# Server Configuration
PORT=5000
APP_URL=http://localhost:3002
NODE_ENV=development

# Security
SESSION_SECRET=your_session_secret_here
CORS_ORIGIN=http://localhost:3000

# Feature Flags
ENABLE_CRISIS_DETECTION=true
ENABLE_AI_STREAMING=true
